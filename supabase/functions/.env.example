# =============================================================================
# Secrets das Edge Functions iGreen
# =============================================================================
# Este arquivo documenta TODAS as variáveis usadas pelas edge functions.
# NÃO contém valores reais — use o painel Lovable / Supabase para configurar.
#
# Como conferir o que está realmente configurado:
#   Lovable: Workspace Settings → Project Settings → Secrets
#   Supabase: https://supabase.com/dashboard/project/zlzasfhcxcznaprrragl/settings/functions
#
# Última atualização: gerado pela auditoria de 24/05/2026.
# =============================================================================

# --- Supabase (auto-injetadas pelo runtime das edge functions) ---------------
SUPABASE_URL=                       # ✅ auto
SUPABASE_ANON_KEY=                  # ✅ auto
SUPABASE_SERVICE_ROLE_KEY=          # ✅ auto — NUNCA expor no frontend
SUPABASE_PUBLISHABLE_KEY=           # ✅ auto (alias de ANON em alguns casos)
SUPABASE_ENV=                       # opcional: 'production' | 'staging'

# --- WhatsApp / Whapi (canal ATIVO atualmente) -------------------------------
WHAPI_TOKEN=                        # OBRIGATÓRIO — token da instância Whapi
WHAPI_API_URL=                      # ex: https://gate.whapi.cloud

# --- WhatsApp / Evolution API (canal espelho/futuro) -------------------------
EVOLUTION_API_URL=                  # ex: https://igreen-evolution-api.b099mi.easypanel.host
EVOLUTION_API_KEY=                  # OBRIGATÓRIO p/ Evolution

# --- AI Gateway (Lovable) ----------------------------------------------------
LOVABLE_API_KEY=                    # ✅ auto via Lovable Cloud — NÃO rotacionar manualmente

# --- AI direto (Gemini / OpenAI) ---------------------------------------------
GEMINI_API_KEY=                     # usado por OCR e ai-generate-step-text
GOOGLE_AI_API_KEY=                  # alias legado de GEMINI_API_KEY (mantido por compat)
OPENAI_API_KEY=                     # usado só pelo intent-classifier (opcional)

# --- MinIO (mídia estática + vídeos comprimidos) -----------------------------
MINIO_SERVER_URL=                   # ex: https://minio.exemplo.com
MINIO_ROOT_USER=                    # admin
MINIO_ROOT_PASSWORD=                # senha
MINIO_BUCKET=                       # ex: igreen
MINIO_TOTAL_BYTES=                  # opcional — total p/ cálculo de % no painel

# --- Worker Portal (cadastros iGreen via Playwright) -------------------------
# ⚠️ Existem 2 nomes pra mesma coisa no codebase. Padronizar para PORTAL_WORKER_URL na Fase 2.
PORTAL_WORKER_URL=                  # nome canônico recomendado
WORKER_PORTAL_URL=                  # alias legado (alguns handlers ainda usam)
WORKER_SECRET=                      # bearer compartilhado worker ↔ edge

# --- Facebook / Meta Ads -----------------------------------------------------
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CAPI_ACCESS_TOKEN=         # CAPI centralizado (pixel global)
FACEBOOK_CAPI_PIXEL_ID=

# --- Observabilidade ---------------------------------------------------------
SENTRY_DSN=                         # opcional — front e edge

# --- Feature flags / debug ---------------------------------------------------
MIDFLOW_QA_ENABLED=                 # 'true' liga QA midflow no bot-flow
FAKE_SB_DEBUG=                      # debug-only, usado em testes

# =============================================================================
# Checklist de deploy novo:
#   1. Todos os marcados "OBRIGATÓRIO" preenchidos
#   2. Whapi vs Evolution: pelo menos um conjunto completo
#   3. MinIO_* completo se for usar upload de mídia
#   4. PORTAL_WORKER_URL configurado se for usar cadastro automático
# =============================================================================
